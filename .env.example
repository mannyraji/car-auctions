# Copy this file to .env and fill in your values
# Never commit .env to source control

# Transport selection for MCP servers: stdio | sse | websocket
TRANSPORT=stdio

# HTTP port for SSE transport
PORT=3000

# WebSocket port for websocket transport
WS_PORT=3001

# Proxy URL for browser pool (optional)
# PROXY_URL=http://user:pass@proxy-host:8080

# OpenTelemetry OTLP endpoint (optional — leave unset to disable tracing)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Node environment
NODE_ENV=development
